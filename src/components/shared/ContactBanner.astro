---
import Button from "../ui/Button.astro";
---

<section class="banner">
  <div class="banner-main">
    <h2 class="banner-title">Interested in working together on a project?</h2>
    <p class="banner-text">
      Occasionally I take on projects that I find interesting, get in touch with
      me and let’s talk.
    </p>
  </div>
  <Button url="mailto:this.eduardo@gmail.com" label="Contact me" />
</section>

<style>
  .banner {
    --padding: 64px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    text-align: center;
    padding-block: var(--padding);

    @media (min-width: 720px) {
      --pading: 96px;
    }
  }

  .banner-main {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .banner-title {
    line-height: 1.4;
    font-size: 1.75rem;
    font-weight: 500;

    @media (min-width: 720px) {
      line-height: 1.3;
      font-size: 2rem;
    }
  }

  .banner-text {
    color: var(--light-text);
    line-height: 1.6;
    font-size: 1rem;
    font-weight: 500;
    max-width: 520px;

    @media (min-width: 720px) {
      line-height: 1.5;
      font-size: 1.25rem;
    }
  }
</style>
