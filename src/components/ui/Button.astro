---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"a"> {
  url: string;
  label: string;
}

const { url, label, ...attrs } = Astro.props;

import Icon from "./Icon.astro";
---

<a class="button" href={url} {...attrs}>
  {label}
  <Icon id="arrow-right" size={20} />
</a>

<style>
  .button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    appearance: none;
    text-decoration: none;
    border: none;
    cursor: pointer;
    color: var(--background);
    line-height: 1.2;
    font-size: 1.125rem;
    border-radius: 100px;
    padding: 16px 24px;
    background-image: linear-gradient(to right, var(--accent) 50%, var(--foreground) 50%);
    background-size: 200% 100%;
    background-position: right center;
    transition: background-position 0.4s cubic-bezier(0.4, 0, 0.2, 1);

    @media (min-width: 1024px) {
      font-size: 1.5rem;
      padding: 24px 40px;
    }

    &:hover {
      background-position: left center;
    }
  }
</style>
